<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>A&amp;A Geotechnical Instrumentation – Login</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --blue-900: #0A2540; --blue-700: #1A4B8C; --blue-500: #2D7DD2;
    --blue-400: #4A9EE8; --blue-100: #DBEEFF; --blue-50: #EEF6FF;
    --white: #FFFFFF; --gray-50: #F7F9FC; --gray-100: #EEF1F6;
    --gray-200: #D8DFE9; --gray-400: #8A96A8; --gray-600: #4A5568;
    --gray-900: #1A202C; --red-500: #E53E3E; --red-50: #FFF5F5;
    --green-500: #2F855A; --green-50: #F0FFF4;
  }
  html, body { min-height: 100%; background: var(--gray-50); font-family: 'DM Sans', sans-serif; color: var(--gray-900); }
  body::before {
    content: ''; position: fixed; inset: 0;
    background-image: linear-gradient(var(--gray-200) 1px, transparent 1px), linear-gradient(90deg, var(--gray-200) 1px, transparent 1px);
    background-size: 40px 40px; opacity: 0.4; pointer-events: none; z-index: 0;
  }
  .left-accent { position: fixed; left: 0; top: 0; bottom: 0; width: 5px; background: linear-gradient(180deg, var(--blue-500) 0%, var(--blue-700) 60%, var(--blue-900) 100%); z-index: 10; }
  .page { position: relative; z-index: 1; min-height: 100vh; display: grid; grid-template-columns: 1fr 480px 1fr; align-items: center; padding: 2rem 2rem 2rem 2.5rem; }
  .brand-panel { grid-column: 1; padding-right: 3rem; }
  .brand-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--blue-50); border: 1px solid var(--blue-100); border-radius: 20px; padding: 5px 12px; font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue-700); margin-bottom: 1.5rem; }
  .brand-badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--blue-500); }
  .brand-panel h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.6rem,3.5vw,4rem); line-height: 1.08; letter-spacing: 0.04em; color: var(--blue-900); margin-bottom: 1.25rem; }
  .brand-panel h1 span { color: var(--blue-500); }
  .brand-panel p { font-size: 14px; color: var(--gray-600); line-height: 1.75; max-width: 280px; margin-bottom: 2rem; }
  .feature-list { display: flex; flex-direction: column; gap: 10px; }
  .feature-item { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--gray-600); }
  .feature-item .dot { width: 28px; height: 28px; border-radius: 8px; background: var(--blue-50); border: 1px solid var(--blue-100); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .feature-item .dot svg { width: 14px; height: 14px; color: var(--blue-500); }
  .login-card { grid-column: 2; background: var(--white); border-radius: 20px; border: 1px solid var(--gray-200); overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.04), 0 20px 60px rgba(0,0,0,0.08); }
  .card-header { background: var(--blue-900); padding: 2rem 2.5rem 1.75rem; position: relative; overflow: hidden; }
  .card-header::after { content: ''; position: absolute; right: -30px; top: -30px; width: 120px; height: 120px; border-radius: 50%; background: rgba(255,255,255,0.04); }
  .logo-area { display: flex; align-items: center; gap: 14px; position: relative; z-index: 1; }
  .logo-icon { width: 50px; height: 50px; flex-shrink: 0; }
  .logo-text .company { font-family: 'Bebas Neue', sans-serif; font-size: 21px; letter-spacing: 0.06em; color: #fff; line-height: 1; }
  .logo-text .company span { color: var(--blue-400); }
  .logo-text .sub { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-top: 3px; }
  .card-body { padding: 2rem 2.5rem 2.5rem; }
  .form-heading { font-size: 18px; font-weight: 600; color: var(--gray-900); margin-bottom: 4px; }
  .form-sub { font-size: 13px; color: var(--gray-400); margin-bottom: 1.75rem; }
  .field { margin-bottom: 1rem; }
  .field label { display: block; font-size: 12.5px; font-weight: 500; color: var(--gray-600); margin-bottom: 6px; }
  .input-wrap { position: relative; }
  .input-wrap .field-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--gray-400); pointer-events: none; }
  .input-wrap input { width: 100%; background: var(--gray-50); border: 1.5px solid var(--gray-200); border-radius: 10px; color: var(--gray-900); font-family: 'DM Sans', sans-serif; font-size: 14px; padding: 10px 14px 10px 40px; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
  .input-wrap input::placeholder { color: var(--gray-400); }
  .input-wrap input:focus { border-color: var(--blue-500); background: var(--white); box-shadow: 0 0 0 3px rgba(45,125,210,0.12); }
  .toggle-pw { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--gray-400); display: flex; align-items: center; padding: 2px; transition: color 0.2s; }
  .toggle-pw:hover { color: var(--gray-600); }
  .field-row { display: flex; align-items: center; justify-content: space-between; margin: 0.75rem 0 1.5rem; }
  .remember { display: flex; align-items: center; gap: 7px; font-size: 13px; color: var(--gray-600); cursor: pointer; user-select: none; }
  .remember input[type="checkbox"] { width: 15px; height: 15px; accent-color: var(--blue-500); cursor: pointer; }
  .btn-login { width: 100%; background: var(--blue-500); color: #fff; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 0.04em; border: none; border-radius: 10px; padding: 12px; cursor: pointer; transition: background 0.2s, transform 0.1s; display: flex; align-items: center; justify-content: center; gap: 8px; }
  .btn-login:hover { background: var(--blue-700); }
  .btn-login:active { transform: scale(0.99); }
  .alert-box { border-radius: 8px; font-size: 13px; padding: 10px 13px; margin-bottom: 1rem; display: none; align-items: center; gap: 8px; }
  .alert-error { background: var(--red-50); border: 1px solid #FED7D7; color: var(--red-500); }
  .alert-box.show { display: flex; }
  .card-footer { padding: 1rem 2.5rem 1.25rem; border-top: 1px solid var(--gray-100); background: var(--gray-50); display: flex; align-items: center; justify-content: space-between; }
  .card-footer p { font-size: 12px; color: var(--gray-400); }
  .card-footer a { font-size: 12px; color: var(--blue-500); text-decoration: none; font-weight: 500; }
  .depth-panel { grid-column: 3; padding-left: 3rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .stat-chip { background: var(--white); border: 1px solid var(--gray-200); border-radius: 12px; padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 4px; width: 195px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .stat-chip .chip-label { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray-400); }
  .stat-chip .chip-value { font-family: 'Bebas Neue', sans-serif; font-size: 26px; letter-spacing: 0.04em; color: var(--blue-700); line-height: 1; }
  .stat-chip .chip-value.safe { color: var(--green-500); }
  .stat-chip .chip-unit { font-size: 11px; color: var(--gray-400); }
  .stat-chip .chip-bar { margin-top: 6px; height: 3px; background: var(--gray-100); border-radius: 2px; overflow: hidden; }
  .stat-chip .chip-bar-fill { height: 100%; background: var(--blue-500); border-radius: 2px; }
  .bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 10; background: rgba(255,255,255,0.92); border-top: 1px solid var(--gray-200); backdrop-filter: blur(8px); padding: 9px 2.5rem; display: flex; align-items: center; justify-content: space-between; }
  .bottom-status { display: flex; align-items: center; gap: 7px; font-size: 12px; color: var(--gray-400); }
  .status-dot { width: 7px; height: 7px; border-radius: 50%; background: #38A169; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.4} }
  .bottom-links { display: flex; gap: 1.5rem; }
  .bottom-links a { font-size: 12px; color: var(--gray-400); text-decoration: none; transition: color 0.2s; }
  .bottom-links a:hover { color: var(--blue-500); }
  @media (max-width: 900px) {
    .page { grid-template-columns: 1fr; padding: 1.5rem 1rem 5rem; }
    .brand-panel, .depth-panel { display: none; }
    .login-card { grid-column: 1; max-width: 420px; margin: 0 auto; width: 100%; }
  }
</style>
</head>
<body>

<div class="left-accent"></div>

<div class="page">

  <div class="brand-panel">
    <div class="brand-badge">Admin Portal</div>
    <h1><span>A&amp;A</span><br>Geotechnical<br>Solutions</h1>
    <p>Advanced monitoring &amp; instrumentation for geotechnical engineers.</p>
    <div class="feature-list">
      <div class="feature-item">
        <div class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
        Real-time sensor monitoring
      </div>
      <div class="feature-item">
        <div class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
        Multi-site borehole management
      </div>
      <div class="feature-item">
        <div class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg></div>
        Automated report generation
      </div>
      <div class="feature-item">
        <div class="dot"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        Secure data access control
      </div>
    </div>
  </div>

  <div class="login-card">
    <div class="card-header">
      <div class="logo-area">
        <svg class="logo-icon" viewBox="0 0 50 50" fill="none">
          <polygon points="25,2 46,13.5 46,36.5 25,48 4,36.5 4,13.5" fill="none" stroke="#4A9EE8" stroke-width="1.5" stroke-linejoin="round"/>
          <line x1="25" y1="11" x2="25" y2="39" stroke="#4A9EE8" stroke-width="2" stroke-linecap="round"/>
          <line x1="21" y1="18" x2="25" y2="18" stroke="#4A9EE8" stroke-width="1.2" stroke-linecap="round"/>
          <line x1="21" y1="25" x2="25" y2="25" stroke="#4A9EE8" stroke-width="1.2" stroke-linecap="round"/>
          <line x1="21" y1="32" x2="25" y2="32" stroke="#4A9EE8" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="25" cy="34" r="3.5" fill="#4A9EE8" opacity="0.9"/>
          <circle cx="25" cy="34" r="1.8" fill="#0A2540"/>
          <text x="9" y="29" font-family="'Bebas Neue',sans-serif" font-size="12" fill="white">A</text>
          <text x="32" y="29" font-family="'Bebas Neue',sans-serif" font-size="12" fill="white">A</text>
        </svg>
        <div class="logo-text">
          <div class="company"><span>A&amp;A</span> Geotechnical</div>
          <div class="sub">Instrument Solution — Admin</div>
        </div>
      </div>
    </div>

    <div class="card-body">
      <div class="form-heading">Welcome back</div>
      <div class="form-sub">Sign in to your admin account</div>

      <div class="alert-box alert-error" id="alertError">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span id="alertText">Invalid username or password.</span>
      </div>

      <form id="loginForm" novalidate>
        <div class="field">
          <label for="email">Email / Username</label>
          <div class="input-wrap">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input id="email" type="text" placeholder="jaha343" autocomplete="username" />
          </div>
        </div>

        <div class="field">
          <label for="password">Password</label>
          <div class="input-wrap">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input id="password" type="password" placeholder="••••••••" autocomplete="current-password" />
            <button type="button" class="toggle-pw" id="togglePw" aria-label="Show password">
              <svg id="eyeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="field-row">
          <label class="remember">
            <input type="checkbox" /> Remember me
          </label>
        </div>

        <button type="submit" class="btn-login" id="submitBtn">
          <span id="btnText">Sign In</span>
        </button>
      </form>
    </div>

    <div class="card-footer">
      <p>Need access?</p>
      <a href="mailto:admin@aageotechnical.com">Contact Administrator →</a>
    </div>
  </div>

  <div class="depth-panel">
    <div class="stat-chip">
      <div class="chip-label">Active Sensors</div>
      <div class="chip-value">247</div>
      <div class="chip-unit">online right now</div>
      <div class="chip-bar"><div class="chip-bar-fill" style="width:82%"></div></div>
    </div>
    <div class="stat-chip">
      <div class="chip-label">Monitoring Depth</div>
      <div class="chip-value">1,850</div>
      <div class="chip-unit">metres total</div>
      <div class="chip-bar"><div class="chip-bar-fill" style="width:65%"></div></div>
    </div>
    <div class="stat-chip">
      <div class="chip-label">Data Points Today</div>
      <div class="chip-value">3.2M</div>
      <div class="chip-unit">collected</div>
      <div class="chip-bar"><div class="chip-bar-fill" style="width:91%"></div></div>
    </div>
    <div class="stat-chip">
      <div class="chip-label">Alert Level</div>
      <div class="chip-value safe">SAFE</div>
      <div class="chip-unit">all systems nominal</div>
    </div>
  </div>

</div>

<div class="bottom-bar">
  <div class="bottom-status">
    <div class="status-dot"></div>
    All systems operational
  </div>
  <div class="bottom-links">
    <a href="#">Privacy Policy</a>
    <a href="#">Terms of Use</a>
    <a href="#">Support</a>
    <a href="#">v3.0.0</a>
  </div>
</div>

<script>
  // ==============================
  // APNA EMAIL AUR PASSWORD YAHAN
  // ==============================
  var ADMIN_EMAIL    = "jaha343";
  var ADMIN_PASSWORD = "9542";
  var DASHBOARD_URL  = "./dashboard.html";
  // ==============================

  var form      = document.getElementById('loginForm');
  var emailEl   = document.getElementById('email');
  var passEl    = document.getElementById('password');
  var btnText   = document.getElementById('btnText');
  var alertBox  = document.getElementById('alertError');
  var alertText = document.getElementById('alertText');
  var togglePw  = document.getElementById('togglePw');
  var eyeIcon   = document.getElementById('eyeIcon');

  togglePw.addEventListener('click', function() {
    var show = passEl.type === 'password';
    passEl.type = show ? 'text' : 'password';
    eyeIcon.innerHTML = show
      ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
      : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  });

  emailEl.addEventListener('input', function() { alertBox.classList.remove('show'); });
  passEl.addEventListener('input',  function() { alertBox.classList.remove('show'); });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var email = emailEl.value.trim();
    var pass  = passEl.value;

    if (!email || !pass) {
      alertText.textContent = 'Please enter username and password.';
      alertBox.classList.add('show');
      return;
    }

    if (email === ADMIN_EMAIL && pass === ADMIN_PASSWORD) {
      btnText.textContent = 'Logging in…';
      setTimeout(function() {
        window.location.href = DASHBOARD_URL;
      }, 600);
    } else {
      alertText.textContent = 'Invalid username or password.';
      alertBox.classList.add('show');
    }
  });
</script>

</body>
</html>
